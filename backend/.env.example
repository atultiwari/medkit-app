# medkit backend environment — example.
#
# Copy to `backend/.env.local` and edit. The setup-offline.sh script writes
# this for you on first run with offline-first defaults.
#
# WARNING: .env.local is gitignored. Never commit API keys.

# ───── Provider selection ─────
LLM_PROVIDER=ollama          # ollama | gemini | claude
STT_PROVIDER=whisper         # whisper | deepgram
TTS_PROVIDER=piper           # piper | cartesia
LIVEKIT_MODE=local           # local | cloud

# Optional comma-separated fallback chain. Primary entry must equal LLM_PROVIDER.
# Example for failover from offline → cloud:
#   LLM_FALLBACK_CHAIN=ollama,gemini,claude
LLM_FALLBACK_CHAIN=ollama

# ───── Ollama (offline LLM, default) ─────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_PATIENT=medgemma1.5:4b
OLLAMA_MODEL_ATTENDING=medgemma1.5:4b
OLLAMA_TIMEOUT_SEC=120

# ───── Whisper (offline STT, default) ─────
# Either point at the sidecar or leave WHISPER_URL unset for in-process mode.
WHISPER_URL=http://whisper:5001
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu

# ───── Piper (offline TTS, default) ─────
PIPER_URL=http://piper:5002
PIPER_DEFAULT_VOICE=en_US-ryan-medium

# ───── LiveKit (local OSS) ─────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=__set_by_setup_offline_sh__

# ───── Optional cloud providers ─────
# Gemini (optional fallback)
# GEMINI_API_KEY=
# GEMINI_MODEL_PATIENT=gemini-1.5-flash
# GEMINI_MODEL_ATTENDING=gemini-1.5-pro

# Anthropic Claude (last-priority fallback)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL_PATIENT=claude-haiku-4-5
# CLAUDE_MODEL_ATTENDING=claude-opus-4-7

# Deepgram / Cartesia (used only if STT_PROVIDER/TTS_PROVIDER switched to cloud)
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=

# ───── Managed Agents (only when LLM_PROVIDER=claude) ─────
# Cached IDs for the persistent Managed Agent + Environment.
# First run: leave blank, start the server, POST /agent/bootstrap,
# then paste the returned ids back here and restart.
# MEDKIT_AGENT_ID=
# MEDKIT_ENV_ID=

# ───── Misc ─────
# Inter-process auth header for production deploys; localhost bypasses.
BACKEND_SHARED_SECRET=
# Credential vault (EHR demo)
EHR_API_TOKEN=
